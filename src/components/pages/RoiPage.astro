---
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { Locale } from '../../i18n';
import { messages } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const m = messages[locale].roi;
---

<BaseLayout locale={locale} title={m.title} description={m.description}>

  <section class="calc-hero">
    <div class="hero-bg">
      <div class="hero-gradient"></div>
      <div class="hero-grid"></div>
    </div>
    <div class="container hero-content">
      <span class="section-label fade-in">{m.heroLabel}</span>
      <h1 class="calc-hero-title fade-in">{m.heroTitle}<br />{m.heroTitleBr}</h1>
      <p class="calc-hero-subtitle fade-in">{m.heroSubtitle}</p>
    </div>
  </section>

  <section class="section calc-section">
    <div class="container">
      <div class="calc-layout">

        <div class="calc-inputs fade-in">
          <div class="inputs-header">
            <span class="section-label">{m.paramsLabel}</span>
            <h2 class="section-title">{m.paramsTitle}</h2>
          </div>

          <div class="input-group" id="group-team-size">
            <div class="input-label-row">
              <label class="input-label" for="team-size">{m.teamSize}</label>
              <span class="input-hint">{m.qaHint}</span>
            </div>
            <div class="input-control">
              <input type="range" id="team-size" class="range-input" min="1" max="20" value="3" step="1" />
              <input type="number" id="team-size-num" class="num-input" min="1" max="20" value="3" step="1" />
            </div>
          </div>

          <div class="input-group" id="group-salary">
            <div class="input-label-row">
              <label class="input-label" for="salary">{m.salary}</label>
              <span class="input-hint">{m.usdYear}</span>
            </div>
            <div class="input-control">
              <input type="range" id="salary" class="range-input" min="30000" max="200000" value="70000" step="5000" />
              <div class="num-input-wrap">
                <span class="num-prefix">$</span>
                <input type="number" id="salary-num" class="num-input num-input-currency" min="30000" max="200000" value="70000" step="5000" />
              </div>
            </div>
          </div>

          <div class="input-group" id="group-hours">
            <div class="input-label-row">
              <label class="input-label" for="hours">{m.hours}</label>
              <span class="input-hint">{m.perPerson}</span>
            </div>
            <div class="input-control">
              <input type="range" id="hours" class="range-input" min="5" max="40" value="20" step="1" />
              <input type="number" id="hours-num" class="num-input" min="5" max="40" value="20" step="1" />
            </div>
          </div>

          <div class="input-group" id="group-bug-rate">
            <div class="input-label-row">
              <label class="input-label" for="bug-rate">{m.bugRate}</label>
              <span class="input-hint">{m.pctProd}</span>
            </div>
            <div class="input-control">
              <input type="range" id="bug-rate" class="range-input" min="1" max="50" value="15" step="1" />
              <div class="num-input-wrap">
                <input type="number" id="bug-rate-num" class="num-input num-input-pct" min="1" max="50" value="15" step="1" />
                <span class="num-suffix">%</span>
              </div>
            </div>
          </div>

          <div class="input-group" id="group-bug-cost">
            <div class="input-label-row">
              <label class="input-label" for="bug-cost">{m.bugCost}</label>
              <span class="input-hint">{m.usdAvg}</span>
            </div>
            <div class="input-control">
              <input type="range" id="bug-cost" class="range-input" min="100" max="10000" value="2000" step="100" />
              <div class="num-input-wrap">
                <span class="num-prefix">$</span>
                <input type="number" id="bug-cost-num" class="num-input num-input-currency" min="100" max="10000" value="2000" step="100" />
              </div>
            </div>
          </div>

          <div class="input-group" id="group-coverage">
            <div class="input-label-row">
              <label class="input-label" for="coverage">{m.coverage}</label>
              <span class="input-hint">{m.pctAuto}</span>
            </div>
            <div class="input-control">
              <input type="range" id="coverage" class="range-input" min="20" max="95" value="70" step="5" />
              <div class="num-input-wrap">
                <input type="number" id="coverage-num" class="num-input num-input-pct" min="20" max="95" value="70" step="5" />
                <span class="num-suffix">%</span>
              </div>
            </div>
          </div>
        </div>

        <div class="calc-results fade-in">
          <div class="results-header">
            <span class="section-label">{m.resultsLabel}</span>
            <h2 class="section-title">{m.resultsTitle}</h2>
          </div>

          <div class="result-hero-card">
            <span class="result-hero-label">{m.estSavings}</span>
            <span class="result-hero-number" id="out-total-savings">$0</span>
            <span class="result-hero-sub">{m.perYear}</span>
          </div>

          <div class="metrics-grid">
            <div class="metric-card">
              <span class="metric-value" id="out-roi">0%</span>
              <span class="metric-label">{m.roi}</span>
            </div>
            <div class="metric-card">
              <span class="metric-value" id="out-payback">0</span>
              <span class="metric-label">{m.payback}</span>
            </div>
            <div class="metric-card">
              <span class="metric-value" id="out-hours-saved">0</span>
              <span class="metric-label">{m.hoursSaved}</span>
            </div>
            <div class="metric-card">
              <span class="metric-value" id="out-bugs-prevented">0</span>
              <span class="metric-label">{m.bugsPrevented}</span>
            </div>
          </div>

          <div class="breakdown-section">
            <h3 class="breakdown-title">{m.breakdownTitle}</h3>
            <div class="breakdown-bars">
              <div class="breakdown-row">
                <div class="breakdown-info">
                  <span class="breakdown-label">{m.autoSavings}</span>
                  <span class="breakdown-value" id="out-auto-savings">$0</span>
                </div>
                <div class="breakdown-track">
                  <div class="breakdown-fill fill-auto" id="bar-auto" style="width: 0%"></div>
                </div>
              </div>
              <div class="breakdown-row">
                <div class="breakdown-info">
                  <span class="breakdown-label">{m.bugSavings}</span>
                  <span class="breakdown-value" id="out-bug-savings">$0</span>
                </div>
                <div class="breakdown-track">
                  <div class="breakdown-fill fill-bug" id="bar-bug" style="width: 0%"></div>
                </div>
              </div>
            </div>
            <div class="breakdown-detail">
              <div class="detail-row">
                <span class="detail-label">{m.implCost}</span>
                <span class="detail-value" id="out-impl-cost">$0</span>
              </div>
              <div class="detail-row">
                <span class="detail-label">{m.manualCost}</span>
                <span class="detail-value" id="out-manual-cost">$0</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container">
      <div class="cta-inner fade-in">
        <h2 class="cta-title">{m.ctaTitle}<br />{m.ctaTitleBr}<span class="accent">{m.ctaAccent}</span>{m.ctaTitleEnd}</h2>
        <p class="cta-desc">{m.ctaDesc}</p>
        <a href="mailto:szapatamejia193@gmail.com" class="btn btn-primary">
          {m.ctaBtn}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ====== HERO ====== */
  .calc-hero {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 160px 0 100px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(34, 197, 94, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 80% 20%, rgba(34, 197, 94, 0.05) 0%, transparent 50%);
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 50% at 50% 30%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 50% at 50% 30%, black 20%, transparent 70%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .calc-hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin-bottom: 28px;
  }

  .calc-hero-subtitle {
    font-size: clamp(1.05rem, 1.8vw, 1.3rem);
    color: var(--text-secondary);
    max-width: 560px;
    line-height: 1.7;
  }

  /* ====== CALCULATOR LAYOUT ====== */
  .calc-section {
    border-top: 1px solid var(--border);
  }

  .calc-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  @media (min-width: 1024px) {
    .calc-layout {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: start;
    }
  }

  /* ====== INPUTS ====== */
  .inputs-header,
  .results-header {
    margin-bottom: 40px;
  }

  .calc-inputs {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .input-group {
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
  }

  .input-group:last-child {
    border-bottom: none;
  }

  .input-label-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 16px;
  }

  .input-label {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .input-hint {
    font-size: 0.8rem;
    color: var(--text-tertiary);
  }

  .input-control {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  /* Range slider */
  .range-input {
    flex: 1;
    -webkit-appearance: none;
    appearance: none;
    height: 6px;
    border-radius: 3px;
    background: var(--border);
    outline: none;
    cursor: pointer;
  }

  .range-input::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    border: 3px solid var(--bg);
    box-shadow: 0 0 0 1px var(--accent), 0 2px 8px rgba(34, 197, 94, 0.3);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .range-input::-webkit-slider-thumb:hover {
    box-shadow: 0 0 0 1px var(--accent), 0 2px 16px rgba(34, 197, 94, 0.5);
    transform: scale(1.1);
  }

  .range-input::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    border: 3px solid var(--bg);
    box-shadow: 0 0 0 1px var(--accent), 0 2px 8px rgba(34, 197, 94, 0.3);
  }

  .range-input::-moz-range-track {
    height: 6px;
    border-radius: 3px;
    background: var(--border);
  }

  /* Number input */
  .num-input {
    width: 80px;
    padding: 8px 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-elevated);
    color: var(--text);
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    text-align: center;
    outline: none;
    transition: border-color var(--transition);
    -moz-appearance: textfield;
  }

  .num-input::-webkit-inner-spin-button,
  .num-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .num-input:focus {
    border-color: var(--accent);
  }

  .num-input-currency {
    width: 100px;
    text-align: right;
    padding-left: 8px;
  }

  .num-input-pct {
    width: 60px;
    text-align: right;
    padding-right: 8px;
  }

  .num-input-wrap {
    display: flex;
    align-items: center;
    gap: 0;
    position: relative;
  }

  .num-prefix {
    position: absolute;
    left: 12px;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-tertiary);
    z-index: 1;
    pointer-events: none;
  }

  .num-prefix + .num-input-currency {
    padding-left: 24px;
    text-align: right;
  }

  .num-suffix {
    position: absolute;
    right: 12px;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-tertiary);
    pointer-events: none;
  }

  .num-input-pct {
    padding-right: 28px;
  }

  /* ====== RESULTS ====== */
  .calc-results {
    position: sticky;
    top: 100px;
  }

  @media (max-width: 1023px) {
    .calc-results {
      position: static;
    }
  }

  /* Hero savings number */
  .result-hero-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 48px 32px;
    border: 1px solid var(--accent);
    border-radius: 20px;
    background: linear-gradient(180deg, rgba(34, 197, 94, 0.06) 0%, rgba(34, 197, 94, 0.01) 100%);
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
  }

  .result-hero-card::before {
    content: '';
    position: absolute;
    top: -60%;
    left: -20%;
    width: 140%;
    height: 140%;
    background: radial-gradient(ellipse at center top, rgba(34, 197, 94, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .result-hero-label {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 16px;
    position: relative;
  }

  .result-hero-number {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 12px;
    position: relative;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .result-hero-sub {
    font-size: 0.9rem;
    color: var(--text-tertiary);
    position: relative;
  }

  /* Metric cards */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }

  .metric-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 24px 16px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--bg);
    transition: border-color var(--transition), background var(--transition);
  }

  .metric-card:hover {
    border-color: var(--border-light);
    background: var(--bg-elevated);
  }

  .metric-value {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    margin-bottom: 6px;
    transition: color 0.3s ease;
  }

  .metric-label {
    font-size: 0.78rem;
    color: var(--text-tertiary);
    font-weight: 500;
  }

  /* Breakdown */
  .breakdown-section {
    padding: 32px;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--bg);
  }

  .breakdown-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 24px;
    letter-spacing: -0.01em;
  }

  .breakdown-bars {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 24px;
  }

  .breakdown-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .breakdown-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .breakdown-label {
    font-size: 0.88rem;
    color: var(--text-secondary);
  }

  .breakdown-value {
    font-family: var(--font-heading);
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text);
  }

  .breakdown-track {
    width: 100%;
    height: 8px;
    background: var(--border);
    border-radius: 4px;
    overflow: hidden;
  }

  .breakdown-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .fill-auto {
    background: linear-gradient(90deg, var(--accent), #34d399);
  }

  .fill-bug {
    background: linear-gradient(90deg, #3b82f6, #60a5fa);
  }

  .breakdown-detail {
    padding-top: 20px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .detail-label {
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }

  .detail-value {
    font-family: var(--font-heading);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  /* ====== CTA ====== */
  .cta-section {
    border-top: 1px solid var(--border);
  }

  .cta-inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }

  .cta-desc {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    border-radius: 8px;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    transition: all var(--transition);
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg);
  }

  .btn-primary:hover {
    background: #1db954;
    box-shadow: 0 0 30px rgba(34, 197, 94, 0.3);
    transform: translateY(-2px);
  }

  /* ====== RESPONSIVE ====== */
  @media (max-width: 767px) {
    .calc-hero {
      padding: 140px 0 60px;
    }

    .result-hero-card {
      padding: 36px 24px;
    }

    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .metric-card {
      padding: 20px 12px;
    }

    .metric-value {
      font-size: 1.25rem;
    }

    .breakdown-section {
      padding: 24px;
    }

    .input-control {
      gap: 12px;
    }

    .num-input-currency {
      width: 90px;
    }
  }

  /* Pulse animation for hero number updates */
  @keyframes value-pop {
    0% { transform: scale(1); }
    50% { transform: scale(1.04); }
    100% { transform: scale(1); }
  }

  .value-updated {
    animation: value-pop 0.3s ease;
  }
</style>

<script define:vars={{ paybackLtOne: m.paybackLtOne, paybackMo: m.mo }}>
  const inputs = {
    teamSize:   { range: document.getElementById('team-size'),    num: document.getElementById('team-size-num') },
    salary:     { range: document.getElementById('salary'),       num: document.getElementById('salary-num') },
    hours:      { range: document.getElementById('hours'),        num: document.getElementById('hours-num') },
    bugRate:    { range: document.getElementById('bug-rate'),     num: document.getElementById('bug-rate-num') },
    bugCost:    { range: document.getElementById('bug-cost'),     num: document.getElementById('bug-cost-num') },
    coverage:   { range: document.getElementById('coverage'),     num: document.getElementById('coverage-num') },
  };

  const outputs = {
    totalSavings:  document.getElementById('out-total-savings'),
    roi:           document.getElementById('out-roi'),
    payback:       document.getElementById('out-payback'),
    hoursSaved:    document.getElementById('out-hours-saved'),
    bugsPrevented: document.getElementById('out-bugs-prevented'),
    autoSavings:   document.getElementById('out-auto-savings'),
    bugSavings:    document.getElementById('out-bug-savings'),
    barAuto:       document.getElementById('bar-auto'),
    barBug:        document.getElementById('bar-bug'),
    implCost:      document.getElementById('out-impl-cost'),
    manualCost:    document.getElementById('out-manual-cost'),
  };

  function formatCurrency(value) {
    return '$' + Math.round(value).toLocaleString('en-US');
  }

  function formatNumber(value) {
    return Math.round(value).toLocaleString('en-US');
  }

  function getValues() {
    return {
      teamSize:  parseFloat(inputs.teamSize.range.value),
      salary:    parseFloat(inputs.salary.range.value),
      hours:     parseFloat(inputs.hours.range.value),
      bugRate:   parseFloat(inputs.bugRate.range.value),
      bugCost:   parseFloat(inputs.bugCost.range.value),
      coverage:  parseFloat(inputs.coverage.range.value),
    };
  }

  function calculate() {
    var v = getValues();

    var manualCost = v.teamSize * v.salary * (v.hours / 40);
    var automationSavings = manualCost * (v.coverage / 100) * 0.6;

    var monthlyBugs = (v.bugRate / 100) * v.teamSize * 20;
    var annualBugs = monthlyBugs * 12;
    var bugSavings = annualBugs * v.bugCost * (v.coverage / 100) * 0.4;

    var totalSavings = automationSavings + bugSavings;

    var implCost = v.salary * 0.3;
    var roiPct = implCost > 0 ? (totalSavings / implCost) * 100 : 0;
    var monthlySavings = totalSavings / 12;
    var paybackMonths = monthlySavings > 0 ? implCost / monthlySavings : 0;

    var hoursSavedYear = v.teamSize * v.hours * 52 * (v.coverage / 100) * 0.6;
    var bugsPrevented = annualBugs * (v.coverage / 100) * 0.4;

    outputs.totalSavings.textContent = formatCurrency(totalSavings);
    outputs.totalSavings.classList.remove('value-updated');
    void outputs.totalSavings.offsetWidth;
    outputs.totalSavings.classList.add('value-updated');

    outputs.roi.textContent = formatNumber(roiPct) + '%';
    outputs.payback.textContent = paybackMonths < 1 ? paybackLtOne : paybackMonths.toFixed(1) + ' ' + paybackMo;
    outputs.hoursSaved.textContent = formatNumber(hoursSavedYear);
    outputs.bugsPrevented.textContent = formatNumber(bugsPrevented);

    outputs.autoSavings.textContent = formatCurrency(automationSavings);
    outputs.bugSavings.textContent = formatCurrency(bugSavings);

    var maxBar = Math.max(automationSavings, bugSavings, 1);
    outputs.barAuto.style.width = ((automationSavings / maxBar) * 100) + '%';
    outputs.barBug.style.width = ((bugSavings / maxBar) * 100) + '%';

    outputs.implCost.textContent = formatCurrency(implCost);
    outputs.manualCost.textContent = formatCurrency(manualCost);
  }

  function syncPair(rangeEl, numEl) {
    rangeEl.addEventListener('input', function() {
      numEl.value = rangeEl.value;
      updateSliderTrack(rangeEl);
      calculate();
    });
    numEl.addEventListener('input', function() {
      var min = parseFloat(rangeEl.min);
      var max = parseFloat(rangeEl.max);
      var val = parseFloat(numEl.value);
      if (!isNaN(val)) {
        if (val < min) val = min;
        if (val > max) val = max;
        rangeEl.value = val;
        updateSliderTrack(rangeEl);
        calculate();
      }
    });
    numEl.addEventListener('blur', function() {
      var min = parseFloat(rangeEl.min);
      var max = parseFloat(rangeEl.max);
      var val = parseFloat(numEl.value);
      if (isNaN(val) || val < min) { numEl.value = min; rangeEl.value = min; }
      else if (val > max) { numEl.value = max; rangeEl.value = max; }
      updateSliderTrack(rangeEl);
      calculate();
    });
  }

  function updateSliderTrack(rangeEl) {
    var min = parseFloat(rangeEl.min);
    var max = parseFloat(rangeEl.max);
    var val = parseFloat(rangeEl.value);
    var pct = ((val - min) / (max - min)) * 100;
    rangeEl.style.background =
      'linear-gradient(to right, #22c55e 0%, #22c55e ' + pct + '%, #222222 ' + pct + '%, #222222 100%)';
  }

  Object.keys(inputs).forEach(function(key) {
    syncPair(inputs[key].range, inputs[key].num);
    updateSliderTrack(inputs[key].range);
  });

  calculate();
</script>
