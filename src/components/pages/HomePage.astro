---
import type { Locale } from '../../i18n';
import { messages } from '../../i18n';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const m = messages[locale].home;
const desc = messages[locale].layout.defaultDescription;
---

<BaseLayout locale={locale} title={m.title} description={desc}>

  <section class="hero">
    <div class="hero-bg">
      <div class="hero-gradient"></div>
      <div class="hero-grid"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-badge fade-in">
        <span class="badge-dot"></span>
        {m.heroBadge}
      </div>
      <h1 class="hero-name fade-in">
        Santiago<br />Zapata Mejía
      </h1>
      <p class="hero-role fade-in">{m.heroRole}</p>
      <p class="hero-tagline fade-in">
        {m.taglineStart}<span class="highlight">{m.taglineH1}</span>{m.taglineMid}<span class="highlight">{m.taglineH2}</span>{m.taglineEnd}
      </p>
      <div class="hero-actions fade-in">
        <a href="#work" class="btn btn-primary">
          {m.ctaWork}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#contact" class="btn btn-secondary">{m.ctaContact}</a>
        <div class="cv-dropdown">
          <button class="btn btn-cv" aria-expanded="false" aria-haspopup="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2v8M5 7l3 3 3-3M3 12v1.5h10V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {m.ctaCv}
            <svg class="cv-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="cv-dropdown-menu">
            <a href="/Santiago_Zapata_QA_CV_EN.pdf" download>
              <span>English</span>
              <span class="cv-lang-tag">EN</span>
            </a>
            <a href="/Santiago_Zapata_QA_CV_ES.pdf" download>
              <span>Español</span>
              <span class="cv-lang-tag">ES</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section metrics-section" id="impact">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">{m.impactLabel}</span>
        <h2 class="section-title">{m.impactTitle}</h2>
      </div>
      <div class="metrics-grid">
        <div class="metric-card fade-in">
          <div class="metric-value">
            <span class="metric-number" data-target="40">40</span><span class="metric-symbol">%</span>
          </div>
          <p class="metric-label">{m.metricDefects}</p>
          <div class="metric-bar"><div class="metric-bar-fill" style="--fill: 40%"></div></div>
        </div>
        <div class="metric-card fade-in">
          <div class="metric-value">
            <span class="metric-number" data-target="80">80</span><span class="metric-symbol">%</span>
          </div>
          <p class="metric-label">{m.metricCoverage}</p>
          <div class="metric-bar"><div class="metric-bar-fill" style="--fill: 80%"></div></div>
        </div>
        <div class="metric-card fade-in">
          <div class="metric-value">
            <span class="metric-number" data-target="5000">5,000</span><span class="metric-symbol">+</span>
          </div>
          <p class="metric-label">{m.metricUsers}</p>
          <div class="metric-bar"><div class="metric-bar-fill" style="--fill: 65%"></div></div>
        </div>
        <div class="metric-card fade-in">
          <div class="metric-value">
            <span class="metric-number" data-target="30">30</span><span class="metric-symbol">%+</span>
          </div>
          <p class="metric-label">{m.metricRelease}</p>
          <div class="metric-bar"><div class="metric-bar-fill" style="--fill: 30%"></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section experience-section" id="work">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">{m.expLabel}</span>
        <h2 class="section-title">{m.expTitle}</h2>
        <p class="section-subtitle">{m.expSubtitle}</p>
      </div>

      <div class="timeline">
        <div class="timeline-item fade-in">
          <div class="timeline-marker">
            <div class="timeline-dot"></div>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-content">
            <div class="timeline-header">
              <div>
                <h3 class="timeline-role">{m.timeline.lingo.role}</h3>
                <p class="timeline-company">{m.timeline.lingo.company} <span class="timeline-tag">{m.timeline.lingo.tag}</span></p>
              </div>
              <span class="timeline-date">{m.timeline.lingo.date}</span>
            </div>
            <ul class="timeline-list">
              {m.timeline.lingo.bullets.map((b) => (
                <li set:html={b} />
              ))}
            </ul>
            <div class="timeline-tags">
              {m.timeline.lingo.tags.map((t) => <span>{t}</span>)}
            </div>
          </div>
        </div>

        <div class="timeline-item fade-in">
          <div class="timeline-marker">
            <div class="timeline-dot"></div>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-content">
            <div class="timeline-header">
              <div>
                <h3 class="timeline-role">{m.timeline.dailybot.role}</h3>
                <p class="timeline-company">{m.timeline.dailybot.company} <span class="timeline-tag">{m.timeline.dailybot.tag}</span></p>
              </div>
              <span class="timeline-date">{m.timeline.dailybot.date}</span>
            </div>
            <ul class="timeline-list">
              {m.timeline.dailybot.bullets.map((b) => (
                <li set:html={b} />
              ))}
            </ul>
            <div class="timeline-tags">
              {m.timeline.dailybot.tags.map((t) => <span>{t}</span>)}
            </div>
          </div>
        </div>

        <div class="timeline-item fade-in">
          <div class="timeline-marker">
            <div class="timeline-dot"></div>
          </div>
          <div class="timeline-content">
            <div class="timeline-header">
              <div>
                <h3 class="timeline-role">{m.timeline.freelance.role}</h3>
                <p class="timeline-company">{m.timeline.freelance.company} <span class="timeline-tag">{m.timeline.freelance.tag}</span></p>
              </div>
              <span class="timeline-date">{m.timeline.freelance.date}</span>
            </div>
            <ul class="timeline-list">
              {m.timeline.freelance.bullets.map((b) => (
                <li set:html={b} />
              ))}
            </ul>
            <div class="timeline-tags">
              {m.timeline.freelance.tags.map((t) => <span>{t}</span>)}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section projects-section" id="projects">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">{m.projLabel}</span>
        <h2 class="section-title">{m.projTitle}</h2>
      </div>

      <div class="projects-grid">
        <a href="https://github.com/ZapataMejia/playwright-automation-framework" target="_blank" rel="noopener noreferrer" class="project-card fade-in">
          <div class="project-card-header">
            <svg class="project-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7l6-3 6 3 6-3v13l-6 3-6-3-6 3V7z"/><path d="M9 4v13M15 7v13"/></svg>
            <svg class="project-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 15L15 5M15 5H8M15 5v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="project-title">{m.projects.playwright.title}</h3>
          <p class="project-desc">{m.projects.playwright.desc}</p>
          <div class="project-tags">
            <span>Playwright</span>
            <span>TypeScript</span>
            <span>CI/CD</span>
            <span>POM</span>
          </div>
        </a>

        <a href="https://github.com/ZapataMejia/cypress-e2e-boilerplate" target="_blank" rel="noopener noreferrer" class="project-card fade-in">
          <div class="project-card-header">
            <svg class="project-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7l6-3 6 3 6-3v13l-6 3-6-3-6 3V7z"/><path d="M9 4v13M15 7v13"/></svg>
            <svg class="project-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 15L15 5M15 5H8M15 5v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="project-title">{m.projects.cypress.title}</h3>
          <p class="project-desc">{m.projects.cypress.desc}</p>
          <div class="project-tags">
            <span>Cypress</span>
            <span>JavaScript</span>
            <span>API Testing</span>
            <span>Visual Regression</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section skills-section">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">{m.skillsLabel}</span>
        <h2 class="section-title">{m.skillsTitle}</h2>
      </div>

      <div class="skills-grid">
        <div class="skill-group fade-in">
          <h3 class="skill-group-title">{m.skillGroupAutomation}</h3>
          <div class="skill-tags">
            <span>Playwright</span>
            <span>Cypress</span>
            <span>Selenium</span>
            <span>Appium</span>
            <span>Jest</span>
            <span>Mocha</span>
            <span>API Testing</span>
            <span>Visual Regression</span>
          </div>
        </div>
        <div class="skill-group fade-in">
          <h3 class="skill-group-title">{m.skillGroupCicd}</h3>
          <div class="skill-tags">
            <span>GitHub Actions</span>
            <span>Jenkins</span>
            <span>Docker</span>
            <span>AWS</span>
            <span>Vercel</span>
            <span>GitLab CI</span>
          </div>
        </div>
        <div class="skill-group fade-in">
          <h3 class="skill-group-title">{m.skillGroupProgramming}</h3>
          <div class="skill-tags">
            <span>TypeScript</span>
            <span>JavaScript</span>
            <span>Python</span>
            <span>Node.js</span>
            <span>React</span>
            <span>Astro</span>
            <span>SQL</span>
          </div>
        </div>
        <div class="skill-group fade-in">
          <h3 class="skill-group-title">{m.skillGroupStrategy}</h3>
          <div class="skill-tags">
            <span>QA Strategy</span>
            <span>Test Architecture</span>
            <span>Team Building</span>
            <span>Agile / Scrum</span>
            <span>Risk Analysis</span>
            <span>Process Design</span>
          </div>
        </div>
        <div class="skill-group fade-in">
          <h3 class="skill-group-title">{m.skillGroupTools}</h3>
          <div class="skill-tags">
            <span>Jira</span>
            <span>TestRail</span>
            <span>Postman</span>
            <span>Figma</span>
            <span>Linear</span>
            <span>Notion</span>
            <span>Datadog</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section speaking-section">
    <div class="container">
      <div class="speaking-card fade-in">
        <div class="speaking-content">
          <span class="section-label">{m.speakLabel}</span>
          <h2 class="section-title">{m.speakTitle}</h2>
          <p class="speaking-desc" set:html={m.speakDesc} />
          <div class="speaking-stats">
            <div class="speaking-stat">
              <span class="speaking-stat-number">5</span>
              <span class="speaking-stat-label">{m.speakStat1}</span>
            </div>
            <div class="speaking-stat">
              <span class="speaking-stat-number">1</span>
              <span class="speaking-stat-label">{m.speakStat2}</span>
            </div>
          </div>
        </div>
        <div class="speaking-visual">
          <div class="speaking-graphic">
            <div class="speaking-circle"></div>
            <div class="speaking-lines">
              <span></span><span></span><span></span><span></span><span></span>
            </div>
            <span class="speaking-icon">🎤</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section contact-section" id="contact">
    <div class="container">
      <div class="contact-inner fade-in">
        <span class="section-label">{m.contactLabel}</span>
        <h2 class="contact-title">{m.contactTitleLine1}<br /><span class="accent">{m.contactTitleAccent}</span> {m.contactTitleLine2}</h2>
        <p class="contact-desc">{m.contactDesc}</p>
        <div class="contact-links">
          <a href="mailto:szapatamejia193@gmail.com" class="contact-link">
            <span class="contact-link-label">Email</span>
            <span class="contact-link-value">szapatamejia193@gmail.com</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 15L15 5M15 5H8M15 5v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="https://github.com/ZapataMejia" target="_blank" rel="noopener noreferrer" class="contact-link">
            <span class="contact-link-label">GitHub</span>
            <span class="contact-link-value">github.com/ZapataMejia</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 15L15 5M15 5H8M15 5v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="https://linkedin.com/in/zapatamejia" target="_blank" rel="noopener noreferrer" class="contact-link">
            <span class="contact-link-label">LinkedIn</span>
            <span class="contact-link-value">linkedin.com/in/zapatamejia</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 15L15 5M15 5H8M15 5v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/Santiago_Zapata_QA_CV_EN.pdf" download class="contact-link">
            <span class="contact-link-label">CV</span>
            <span class="contact-link-value">{m.contactCvValue}</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 3v10M6 9l4 4 4-4M4 15v2h12v-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
<style>
  /* ====== HERO ====== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 80px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(34, 197, 94, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 80% 20%, rgba(34, 197, 94, 0.05) 0%, transparent 50%);
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 50% at 50% 30%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 50% at 50% 30%, black 20%, transparent 70%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 40px;
    padding-bottom: 80px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    color: var(--accent);
    border: 1px solid rgba(34, 197, 94, 0.25);
    padding: 8px 18px;
    border-radius: 100px;
    margin-bottom: 40px;
    background: rgba(34, 197, 94, 0.05);
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
    50% { opacity: 0.8; box-shadow: 0 0 0 8px rgba(34, 197, 94, 0); }
  }

  .hero-name {
    font-family: var(--font-heading);
    font-size: clamp(3.2rem, 10vw, 7rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin-bottom: 24px;
  }

  .hero-role {
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 28px;
    letter-spacing: -0.01em;
  }

  .hero-tagline {
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    color: var(--text-secondary);
    max-width: 600px;
    line-height: 1.7;
    margin-bottom: 48px;
  }

  .highlight {
    color: var(--text);
    font-weight: 600;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    border-radius: 8px;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    transition: all var(--transition);
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg);
  }

  .btn-primary:hover {
    background: #1db954;
    box-shadow: 0 0 30px rgba(34, 197, 94, 0.3);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border-light);
  }

  .btn-secondary:hover {
    border-color: var(--text-tertiary);
    background: var(--bg-elevated);
    transform: translateY(-2px);
  }

  /* ====== CV DROPDOWN ====== */
  .cv-dropdown {
    position: relative;
  }

  .btn-cv {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border-light);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .btn-cv:hover {
    border-color: var(--text-tertiary);
    background: var(--bg-elevated);
    transform: translateY(-2px);
  }

  .cv-chevron {
    transition: transform var(--transition);
  }

  .cv-dropdown.open .cv-chevron {
    transform: rotate(180deg);
  }

  .cv-dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 180px;
    background: var(--bg-elevated);
    border: 1px solid var(--border-light);
    border-radius: 10px;
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: all var(--transition);
    z-index: 10;
  }

  .cv-dropdown.open .cv-dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .cv-dropdown-menu a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 18px;
    font-size: 0.9rem;
    color: var(--text-secondary);
    transition: all var(--transition);
  }

  .cv-dropdown-menu a:hover {
    background: var(--bg-card);
    color: var(--text);
  }

  .cv-dropdown-menu a + a {
    border-top: 1px solid var(--border);
  }

  .cv-lang-tag {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--accent-dim);
    color: var(--accent);
  }

  /* ====== METRICS ====== */
  .metrics-section {
    border-top: 1px solid var(--border);
  }

  .section-header {
    margin-bottom: 64px;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .metrics-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .metric-card {
    padding: 40px 32px;
    background: var(--bg);
    text-align: center;
  }

  .metric-value {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 8px;
    line-height: 1;
  }

  .metric-symbol {
    color: var(--accent);
  }

  .metric-label {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 20px;
  }

  .metric-bar {
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    max-width: 120px;
    margin: 0 auto;
  }

  .metric-bar-fill {
    height: 100%;
    width: 0;
    background: var(--accent);
    border-radius: 2px;
    transition: width 1.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .metric-card.in-view .metric-bar-fill {
    width: var(--fill);
  }

  /* ====== EXPERIENCE ====== */
  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: flex;
    gap: 32px;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    padding-top: 6px;
  }

  .timeline-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid var(--accent);
