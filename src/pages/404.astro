---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found">
  <section class="error-page">
    <div class="container">
      <div class="error-content fade-in">
        <div class="error-code">
          <span class="error-4">4</span>
          <span class="error-0">
            <span class="error-circle"></span>
          </span>
          <span class="error-4">4</span>
        </div>
        <h1 class="error-title">This page failed QA.</h1>
        <p class="error-desc">
          Looks like this URL didn't pass our test suite. 
          Let's get you back on track.
        </p>
        <div class="error-actions">
          <a href="/" class="btn btn-primary">
            Back to Home
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/blog" class="btn btn-secondary">Read the Blog</a>
        </div>
        <div class="error-log">
          <code>
            <span class="log-red">FAIL</span> pages/this-page.spec.ts<br />
            <span class="log-dim">  ✕ should exist (404ms)</span><br />
            <span class="log-dim">  ✕ should have content (timeout)</span><br /><br />
            <span class="log-red">Test Suites: 1 failed</span>, 0 passed<br />
            <span class="log-dim">Ran all test suites.</span>
          </code>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .error-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 0 80px;
  }

  .error-content {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .error-code {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 32px;
  }

  .error-4 {
    font-family: var(--font-heading);
    font-size: clamp(5rem, 12vw, 8rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--text);
  }

  .error-0 {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .error-circle {
    display: block;
    width: clamp(60px, 10vw, 90px);
    height: clamp(60px, 10vw, 90px);
    border-radius: 50%;
    border: 4px solid var(--accent);
    animation: pulse-ring 2s ease-in-out infinite;
  }

  @keyframes pulse-ring {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.3); }
    50% { box-shadow: 0 0 0 16px rgba(34, 197, 94, 0); }
  }

  .error-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .error-desc {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .error-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 56px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    border-radius: 8px;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg);
  }

  .btn-primary:hover {
    background: #1db954;
    box-shadow: 0 0 30px rgba(34, 197, 94, 0.3);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border-light);
  }

  .btn-secondary:hover {
    border-color: var(--text-tertiary);
    background: var(--bg-elevated);
    transform: translateY(-2px);
  }

  .error-log {
    text-align: left;
    padding: 24px 28px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    font-size: 0.82rem;
    line-height: 1.8;
  }

  .error-log code {
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
    color: var(--text-secondary);
  }

  .log-red {
    color: #ef4444;
    font-weight: 600;
  }

  .log-dim {
    color: var(--text-tertiary);
  }
</style>
