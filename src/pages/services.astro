---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Services — Santiago Zapata Mejía | QA Engineering Consulting" description="Quality Engineering consulting services: QA program setup, test automation architecture, and QA audits. From zero to fully automated.">

  <!-- HERO -->
  <section class="services-hero">
    <div class="hero-bg">
      <div class="hero-gradient"></div>
      <div class="hero-grid"></div>
    </div>
    <div class="container hero-content">
      <span class="section-label fade-in">Services</span>
      <h1 class="services-hero-title fade-in">Quality Engineering<br />Services</h1>
      <p class="services-hero-subtitle fade-in">
        From zero to fully automated — I build QA programs that let your team ship faster.
      </p>
    </div>
  </section>

  <!-- SERVICE PACKAGES -->
  <section class="section packages-section" id="packages">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">Packages</span>
        <h2 class="section-title">How I can help</h2>
        <p class="section-subtitle">Three focused engagements designed to meet you where you are.</p>
      </div>

      <div class="packages-grid">
        <div class="package-card fade-in">
          <div class="package-number">01</div>
          <div class="package-badge">Starting from Zero</div>
          <h3 class="package-title">QA Program Setup</h3>
          <ul class="package-list">
            <li>Test strategy definition</li>
            <li>Framework architecture (Playwright/Cypress)</li>
            <li>CI/CD pipeline integration</li>
            <li>Team onboarding &amp; documentation</li>
          </ul>
          <div class="package-meta">
            <div class="package-meta-item">
              <span class="package-meta-label">Best for</span>
              <span class="package-meta-value">Startups with no QA processes</span>
            </div>
            <div class="package-meta-item">
              <span class="package-meta-label">Timeline</span>
              <span class="package-meta-value">4–8 weeks</span>
            </div>
          </div>
        </div>

        <div class="package-card featured fade-in">
          <div class="package-number">02</div>
          <div class="package-badge">Scale Your Testing</div>
          <h3 class="package-title">Test Automation Architecture</h3>
          <ul class="package-list">
            <li>Framework design &amp; implementation</li>
            <li>Page Object Model architecture</li>
            <li>API + E2E test coverage</li>
            <li>Reporting &amp; monitoring setup</li>
          </ul>
          <div class="package-meta">
            <div class="package-meta-item">
              <span class="package-meta-label">Best for</span>
              <span class="package-meta-value">Teams with manual testing wanting to automate</span>
            </div>
            <div class="package-meta-item">
              <span class="package-meta-label">Timeline</span>
              <span class="package-meta-value">2–6 weeks</span>
            </div>
          </div>
        </div>

        <div class="package-card fade-in">
          <div class="package-number">03</div>
          <div class="package-badge">Optimize What Exists</div>
          <h3 class="package-title">QA Consulting &amp; Audit</h3>
          <ul class="package-list">
            <li>Current QA process audit</li>
            <li>Gap analysis &amp; recommendations</li>
            <li>Test strategy optimization</li>
            <li>CI/CD pipeline review</li>
          </ul>
          <div class="package-meta">
            <div class="package-meta-item">
              <span class="package-meta-label">Best for</span>
              <span class="package-meta-value">Teams with existing QA wanting improvement</span>
            </div>
            <div class="package-meta-item">
              <span class="package-meta-label">Timeline</span>
              <span class="package-meta-value">1–2 weeks</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section process-section" id="process">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">Process</span>
        <h2 class="section-title">How we work together</h2>
        <p class="section-subtitle">A clear, proven process from first conversation to lasting results.</p>
      </div>

      <div class="process-grid">
        <div class="process-step fade-in">
          <div class="process-number">1</div>
          <h3 class="process-step-title">Discovery Call</h3>
          <p class="process-step-desc">Understand your needs, tech stack, and pain points.</p>
        </div>
        <div class="process-connector fade-in" aria-hidden="true">
          <svg width="40" height="12" viewBox="0 0 40 12" fill="none"><path d="M0 6h32M28 1l6 5-6 5" stroke="var(--border-light)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="process-step fade-in">
          <div class="process-number">2</div>
          <h3 class="process-step-title">Strategy &amp; Proposal</h3>
          <p class="process-step-desc">Detailed plan with timeline and deliverables.</p>
        </div>
        <div class="process-connector fade-in" aria-hidden="true">
          <svg width="40" height="12" viewBox="0 0 40 12" fill="none"><path d="M0 6h32M28 1l6 5-6 5" stroke="var(--border-light)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="process-step fade-in">
          <div class="process-number">3</div>
          <h3 class="process-step-title">Implementation</h3>
          <p class="process-step-desc">Build, integrate, document, and test.</p>
        </div>
        <div class="process-connector fade-in" aria-hidden="true">
          <svg width="40" height="12" viewBox="0 0 40 12" fill="none"><path d="M0 6h32M28 1l6 5-6 5" stroke="var(--border-light)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="process-step fade-in">
          <div class="process-number">4</div>
          <h3 class="process-step-title">Handoff &amp; Support</h3>
          <p class="process-step-desc">Team training, documentation, and ongoing support.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section" id="faq">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">FAQ</span>
        <h2 class="section-title">Common questions</h2>
      </div>

      <div class="faq-list">
        <details class="faq-item fade-in">
          <summary class="faq-question">
            <span>What tools do you work with?</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="faq-answer">
            <p>My core stack includes <strong>Playwright</strong> and <strong>Cypress</strong> for E2E testing, <strong>TypeScript/JavaScript</strong> for test scripting, and <strong>GitHub Actions</strong>, <strong>Jenkins</strong>, and <strong>GitLab CI</strong> for pipeline integration. I also work with Jest, Mocha, Postman for API testing, and tools like TestRail, Jira, and Datadog for reporting and monitoring.</p>
          </div>
        </details>

        <details class="faq-item fade-in">
          <summary class="faq-question">
            <span>Do you work with remote teams?</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="faq-answer">
            <p>Absolutely. I've worked with distributed teams across the <strong>US and Latin America</strong>. I'm comfortable with async communication, overlap-friendly scheduling, and tools like Slack, Notion, and Linear. Most of my engagements are fully remote.</p>
          </div>
        </details>

        <details class="faq-item fade-in">
          <summary class="faq-question">
            <span>How long does a typical engagement take?</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="faq-answer">
            <p>It depends on the scope. A <strong>QA audit</strong> can be done in 1–2 weeks. <strong>Test automation architecture</strong> typically takes 2–6 weeks. A full <strong>QA program setup</strong> from scratch ranges from 4–8 weeks. We'll define the timeline together during the discovery call.</p>
          </div>
        </details>

        <details class="faq-item fade-in">
          <summary class="faq-question">
            <span>What industries have you worked in?</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="faq-answer">
            <p>I've delivered quality engineering across <strong>EdTech</strong> (LingoQuesto), <strong>SaaS/Productivity</strong> (DailyBot — Y Combinator W19), and various <strong>early-stage startups</strong>. The patterns of building reliable QA programs translate well across domains.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-inner fade-in">
        <h2 class="cta-title">Ready to transform<br />your <span class="accent">QA</span>?</h2>
        <p class="cta-desc">Let's talk about how I can help your team ship faster and with more confidence.</p>
        <a href="mailto:szapatamejia193@gmail.com" class="btn btn-primary">
          Get In Touch
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ====== HERO ====== */
  .services-hero {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 160px 0 100px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(34, 197, 94, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 80% 20%, rgba(34, 197, 94, 0.05) 0%, transparent 50%);
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 50% at 50% 30%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 50% at 50% 30%, black 20%, transparent 70%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .services-hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin-bottom: 28px;
  }

  .services-hero-subtitle {
    font-size: clamp(1.05rem, 1.8vw, 1.3rem);
    color: var(--text-secondary);
    max-width: 560px;
    line-height: 1.7;
  }

  /* ====== PACKAGES ====== */
  .packages-section {
    border-top: 1px solid var(--border);
  }

  .section-header {
    margin-bottom: 64px;
  }

  .packages-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 1024px) {
    .packages-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .package-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 40px 36px;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--bg);
    transition: all var(--transition);
  }

  .package-card:hover {
    border-color: var(--accent);
    background: var(--bg-elevated);
    box-shadow: 0 0 40px rgba(34, 197, 94, 0.06);
    transform: translateY(-4px);
  }

  .package-card.featured {
    border-color: var(--accent);
    background: linear-gradient(180deg, rgba(34, 197, 94, 0.04) 0%, var(--bg) 40%);
  }

  .package-card.featured::before {
    content: 'Most Popular';
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%) translateY(-50%);
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bg);
    background: var(--accent);
    padding: 4px 16px;
    border-radius: 100px;
  }

  .package-number {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 20px;
    opacity: 0.6;
  }

  .package-badge {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-dim);
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
    width: fit-content;
  }

  .package-title {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }

  .package-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 32px;
    flex: 1;
  }

  .package-list li {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
    padding-left: 22px;
    position: relative;
  }

  .package-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid var(--accent);
    opacity: 0.6;
  }

  .package-meta {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .package-meta-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .package-meta-label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-tertiary);
  }

  .package-meta-value {
    font-size: 0.88rem;
    color: var(--text-secondary);
    text-align: right;
  }

  /* ====== PROCESS ====== */
  .process-section {
    border-top: 1px solid var(--border);
  }

  .process-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .process-grid {
      flex-direction: row;
      align-items: flex-start;
      gap: 0;
    }
  }

  .process-step {
    flex: 1;
    text-align: center;
    padding: 32px 24px;
  }

  .process-number {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: 1.5px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent);
    margin: 0 auto 20px;
    background: var(--accent-dim);
  }

  .process-step-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }

  .process-step-desc {
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.6;
    max-width: 220px;
    margin: 0 auto;
  }

  .process-connector {
    display: none;
    align-items: center;
    justify-content: center;
    padding-top: 48px;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .process-connector {
      display: flex;
    }
  }

  /* ====== FAQ ====== */
  .faq-section {
    border-top: 1px solid var(--border);
  }

  .faq-list {
    max-width: 768px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }

  .faq-item {
    background: var(--bg);
    transition: background var(--transition);
  }

  .faq-item[open] {
    background: var(--bg-elevated);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 32px;
    cursor: pointer;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    list-style: none;
    transition: color var(--transition);
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::marker {
    display: none;
    content: '';
  }

  .faq-question:hover {
    color: var(--accent);
  }

  .faq-chevron {
    color: var(--text-tertiary);
    transition: transform var(--transition), color var(--transition);
    flex-shrink: 0;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    color: var(--accent);
  }

  .faq-answer {
    padding: 0 32px 24px;
    animation: faq-reveal 0.3s ease;
  }

  @keyframes faq-reveal {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .faq-answer p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .faq-answer p strong {
    color: var(--text);
    font-weight: 600;
  }

  /* ====== CTA ====== */
  .cta-section {
    border-top: 1px solid var(--border);
  }

  .cta-inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }

  .cta-desc {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    border-radius: 8px;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    transition: all var(--transition);
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg);
  }

  .btn-primary:hover {
    background: #1db954;
    box-shadow: 0 0 30px rgba(34, 197, 94, 0.3);
    transform: translateY(-2px);
  }

  /* ====== RESPONSIVE ====== */
  @media (max-width: 767px) {
    .services-hero {
      padding: 140px 0 60px;
    }

    .faq-question {
      padding: 20px 24px;
      font-size: 0.95rem;
    }

    .faq-answer {
      padding: 0 24px 20px;
    }

    .package-card {
      padding: 32px 28px;
    }
  }
</style>
