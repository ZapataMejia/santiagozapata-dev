---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = "How I Built a QA Program from Zero for a Y Combinator Startup";
const date = "March 10, 2026";
const readTime = "8 min read";

const esc = (s: string) => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

const codeLoginPage = esc(`// pages/LoginPage.ts
import { type Page, type Locator } from '@playwright/test';

export class LoginPage {
  private readonly emailInput: Locator;
  private readonly passwordInput: Locator;
  private readonly submitButton: Locator;

  constructor(private page: Page) {
    this.emailInput = page.locator('[data-testid="email-input"]');
    this.passwordInput = page.locator('[data-testid="password-input"]');
    this.submitButton = page.locator('[data-testid="login-submit"]');
  }

  async login(email: string, password: string) {
    await this.emailInput.fill(email);
    await this.passwordInput.fill(password);
    await this.submitButton.click();
    await this.page.waitForURL('**/dashboard');
  }
}`);

const codeFolderStructure = esc(`tests/
├── e2e/
│   ├── onboarding/
│   │   ├── signup.spec.ts
│   │   └── team-setup.spec.ts
│   ├── check-ins/
│   │   ├── daily-checkin.spec.ts
│   │   └── async-responses.spec.ts
│   ├── integrations/
│   │   ├── slack-connect.spec.ts
│   │   └── teams-connect.spec.ts
│   └── billing/
│       ├── upgrade-plan.spec.ts
│       └── cancel-subscription.spec.ts
├── pages/
│   ├── LoginPage.ts
│   ├── DashboardPage.ts
│   ├── CheckInPage.ts
│   └── BillingPage.ts
├── fixtures/
│   ├── auth.fixture.ts
│   └── test-data.fixture.ts
└── playwright.config.ts`);

const codeAuthFixture = esc(`// fixtures/auth.fixture.ts
import { test as base } from '@playwright/test';

type AuthFixtures = {
  authenticatedPage: Page;
};

export const test = base.extend<AuthFixtures>({
  authenticatedPage: async ({ browser }, use) => {
    const context = await browser.newContext();
    const page = await context.newPage();

    const response = await page.request.post('/api/auth/login', {
      data: {
        email: process.env.TEST_USER_EMAIL,
        password: process.env.TEST_USER_PASSWORD,
      },
    });

    const cookies = response.headers()['set-cookie'];
    await context.addCookies(parseCookies(cookies));
    await use(page);
    await context.close();
  },
});`);

const codeGhActions = esc(`# .github/workflows/e2e-tests.yml
name: E2E Tests
on:
  pull_request:
    branches: [main, develop]

jobs:
  e2e:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 20

      - name: Install dependencies
        run: npm ci

      - name: Install Playwright browsers
        run: npx playwright install --with-deps chromium

      - name: Run critical path tests
        run: npx playwright test --grep @critical
        env:
          BASE_URL: \${{ secrets.STAGING_URL }}
          TEST_USER_EMAIL: \${{ secrets.TEST_USER_EMAIL }}
          TEST_USER_PASSWORD: \${{ secrets.TEST_USER_PASSWORD }}

      - uses: actions/upload-artifact@v4
        if: failure()
        with:
          name: test-results
          path: test-results/`);
---

<BaseLayout locale="en" title={`${title} — Santiago Zapata Mejía`} description="A deep dive into building test automation infrastructure, defining quality processes, and creating a culture of quality from the ground up at DailyBot (YC W19).">
  <article class="article">
    <div class="article-container">
      <a href="/en/blog" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13 8H3M7 4L3 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Back to blog
      </a>

      <header class="article-header fade-in">
        <div class="article-meta">
          <span class="article-tag">Strategy</span>
          <span class="article-date">{date} · {readTime}</span>
        </div>
        <h1 class="article-title">{title}</h1>
        <p class="article-subtitle">A deep dive into building test automation infrastructure, defining quality processes, and creating a culture of quality from the ground up at DailyBot (YC W19).</p>
      </header>

      <div class="article-body fade-in">
        <p>When I joined DailyBot — a Y Combinator W19 startup building async communication tools — there was no QA process. Zero automated tests. No test plans. The engineering team was shipping fast, but bugs were slipping through regularly, and customer-facing issues were eating into development velocity. Every release felt like a coin flip.</p>

        <p>This is the story of how I built a QA program from scratch, took it from zero to a fully automated pipeline, and cut production defects by 40%. If you're a QA engineer or engineering leader staring at a blank canvas, this is for you.</p>

        <h2>The Audit: Understanding What's Actually Broken</h2>

        <p>Before writing a single test, I spent the first two weeks doing something that feels counterintuitive in a startup — I slowed down. I audited everything.</p>

        <p>I mapped out every critical user flow: onboarding, daily check-ins, integrations with Slack and Microsoft Teams, billing, and the admin dashboard. Then I looked at the last 3 months of bug reports and customer support tickets. The patterns were clear:</p>

        <ul>
          <li><strong>Integration flows</strong> (Slack/Teams) accounted for 35% of all reported bugs</li>
          <li><strong>Onboarding and billing</strong> had the highest business impact when they broke</li>
          <li><strong>Regression bugs</strong> made up nearly half of all production issues — things that used to work, broke again</li>
          <li><strong>No one trusted deploys.</strong> Engineers would manually click through the app before each release, adding 2-3 hours per deploy</li>
        </ul>

        <p>This audit gave me the ammunition to build a prioritized roadmap instead of trying to boil the ocean. Rule number one: you can't automate everything at once, and you shouldn't try.</p>

        <h2>Choosing the Stack: Why Playwright and POM</h2>

        <p>The tool decision came down to three contenders: Cypress, Selenium, and Playwright. Here's why Playwright won:</p>

        <ul>
          <li><strong>Multi-browser support out of the box.</strong> DailyBot had a significant user base on Firefox and Safari — not just Chrome. Cypress at the time had limited cross-browser support.</li>
          <li><strong>Native async/await.</strong> Playwright's API is built around Promises. No implicit waits, no flaky <code>cy.wait()</code> hacks. You write the async flow you actually mean.</li>
          <li><strong>Built-in parallelism.</strong> Running tests in parallel across browser contexts without external orchestration was a massive win for CI speed.</li>
          <li><strong>Auto-waiting and network interception.</strong> Playwright waits for elements to be actionable before interacting. Network mocking is first-class, which was critical for testing integrations without hitting real Slack/Teams APIs.</li>
        </ul>

        <p>For architecture, I chose the <strong>Page Object Model (POM)</strong>. In a fast-moving codebase, UI changes constantly. POM isolates selectors and page interactions into dedicated classes, so when the UI changes, you update one file — not fifty tests.</p>

        <pre><code set:html={codeLoginPage}></code></pre>

        <h2>Building the Framework: Structure That Scales</h2>

        <p>I designed the folder structure to be immediately understandable for any developer joining the team. Discoverability matters more than cleverness:</p>

        <pre><code set:html={codeFolderStructure}></code></pre>

        <p>Two patterns made a huge difference for test stability and speed:</p>

        <p><strong>Custom fixtures for authentication.</strong> Instead of logging in through the UI for every single test, I created a fixture that authenticates via the API and injects the session cookie. This alone shaved 40+ seconds off each test run.</p>

        <pre><code set:html={codeAuthFixture}></code></pre>

        <p><strong>Environment-agnostic test data.</strong> Tests generate their own data through API calls in <code>beforeEach</code> hooks, and clean up in <code>afterEach</code>. No shared test accounts, no mysterious failures because someone else's test run corrupted the state.</p>

        <h2>CI/CD Integration: Making Tests Gatekeepers</h2>

        <p>Automated tests are worthless if they don't block bad code from shipping. I integrated the test suite into two pipelines:</p>

        <p><strong>GitHub Actions for PR checks.</strong> Every pull request triggers a subset of critical path tests (login, core check-in flow, billing). This runs in ~4 minutes and gives developers fast feedback.</p>

        <pre><code set:html={codeGhActions}></code></pre>

        <p><strong>Jenkins for full regression suites.</strong> The complete suite (all browsers, all flows) runs nightly and on the staging branch before production deploys. If any test fails, the deploy is blocked automatically.</p>

        <p>I also set up Slack notifications for test results — ironic, given we were building a communication tool, but it meant the whole team had visibility into quality without checking dashboards.</p>

        <h2>The Results</h2>

        <p>After 4 months of building and iterating, the numbers spoke for themselves:</p>

        <ul>
          <li><strong>40% reduction in production defects.</strong> Regressions nearly disappeared. The bugs that did ship were edge cases, not core flow breakages.</li>
          <li><strong>30% faster release cycles.</strong> Engineers stopped manually testing before deploys. The CI pipeline was their confidence layer.</li>
          <li><strong>50% less manual testing effort.</strong> The QA team shifted from repetitive click-through testing to exploratory testing and test design — far more valuable work.</li>
          <li><strong>Developer trust.</strong> This is hard to quantify, but engineers started asking "did we add a test for this?" in code reviews. Quality became a shared responsibility, not a QA bottleneck.</li>
        </ul>

        <h2>Key Lessons Learned</h2>

        <p><strong>Start with the audit, not the tools.</strong> I've seen QA engineers jump straight into setting up Playwright or Cypress without understanding what actually needs testing. The audit is the foundation. Without it, you're automating the wrong things.</p>

        <p><strong>Optimize for developer adoption.</strong> The best test suite in the world is useless if developers don't run it. I made the tests easy to run locally (<code>npm run test:e2e</code>), easy to debug (Playwright's trace viewer is incredible), and easy to write (clear patterns, good fixtures, documented examples).</p>

        <p><strong>Flaky tests are a trust killer.</strong> I treated flaky tests as P0 bugs. Every flaky test was either fixed within 24 hours or quarantined. If developers learn to ignore test failures, you've lost the game.</p>

        <p><strong>Don't aim for 100% coverage.</strong> It's a trap. I targeted the 20% of flows that caused 80% of the bugs. Onboarding, billing, and integration flows — that's where the real value was. We hit 80% coverage of critical paths, not 80% of every button and tooltip.</p>

        <p><strong>Make tests a first-class part of the deploy pipeline.</strong> Tests that run but don't gate deployments are just expensive logs. The moment we made the suite a mandatory pass for production deploys, the team's relationship with tests changed fundamentally.</p>

        <p>Building a QA program from zero is one of the most rewarding things you can do as a quality engineer. You're not just writing tests — you're changing how a team thinks about shipping software. And if you do it right, the impact compounds with every single release.</p>
      </div>

      <div class="article-author fade-in">
        <div class="author-info">
          <div class="author-avatar">SZ</div>
          <div>
            <p class="author-name">Santiago Zapata Mejía</p>
            <p class="author-role">QA Automation Lead · Building quality programs for startups</p>
          </div>
        </div>
      </div>

      <a href="/en/blog" class="back-link back-link-bottom">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13 8H3M7 4L3 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Back to blog
      </a>
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    padding: 120px 0 80px;
  }

  .article-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-heading);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-tertiary);
    transition: color var(--transition);
    margin-bottom: 48px;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .back-link-bottom {
    margin-bottom: 0;
    margin-top: 48px;
  }

  .article-header {
    margin-bottom: 48px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--border);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .article-tag {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    padding: 4px 12px;
    border-radius: 100px;
    border: 1px solid rgba(34, 197, 94, 0.25);
    background: var(--accent-dim);
  }

  .article-date {
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }

  .article-title {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }

  .article-subtitle {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .article-body {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .article-body p {
    margin-bottom: 1.5em;
  }

  .article-body h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text);
    margin-top: 2.5em;
    margin-bottom: 0.8em;
    letter-spacing: -0.01em;
  }

  .article-body h3 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text);
    margin-top: 2em;
    margin-bottom: 0.6em;
  }

