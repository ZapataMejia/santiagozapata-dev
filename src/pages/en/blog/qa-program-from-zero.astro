  .article-body ol {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
  }

  .article-body li {
    margin-bottom: 0.6em;
    line-height: 1.7;
  }

  .article-body strong {
    color: var(--text);
    font-weight: 600;
  }

  .article-body code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.88em;
    background: var(--bg-elevated);
    padding: 2px 8px;
    border-radius: 4px;
    border: 1px solid var(--border);
    color: var(--accent);
  }

  .article-body pre {
    margin-bottom: 1.8em;
    border-radius: 12px;
    overflow-x: auto;
    border: 1px solid var(--border);
    background: #0d0d0d;
  }

