    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-heading);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-tertiary);
    transition: color var(--transition);
    margin-bottom: 48px;
  }
  .back-link:hover {
    color: var(--accent);
  }
  .back-link-bottom {
    margin-bottom: 0;
    margin-top: 48px;
  }
  .article-header {
    margin-bottom: 48px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--border);
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .article-tag {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    padding: 4px 12px;
    border-radius: 100px;
    border: 1px solid rgba(34, 197, 94, 0.25);
    background: var(--accent-dim);
  }
  .article-date {
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }
  .article-title {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }
  .article-subtitle {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.7;
  }
  .article-body {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }
  .article-body p {
    margin-bottom: 1.5em;
  }
  .article-body h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text);
    margin-top: 2.5em;
    margin-bottom: 0.8em;
    letter-spacing: -0.01em;
  }
  .article-body ol {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
  }
  .article-body li {
    margin-bottom: 0.6em;
    line-height: 1.7;
  }
  .article-body ul {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
  }
  .article-body strong {
    color: var(--text);
    font-weight: 600;
  }
  .article-body a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .article-body .tok {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.88em;
    background: var(--bg-elevated);
    padding: 2px 8px;
    border-radius: 4px;
    border: 1px solid var(--border);
    color: var(--accent);
  }
  .article-body code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.88em;
    background: var(--bg-elevated);
    padding: 2px 8px;
    border-radius: 4px;
    border: 1px solid var(--border);
    color: var(--accent);
  }
  .article-body pre.mono-block {
    margin-bottom: 1.8em;
    border-radius: 12px;
    overflow-x: auto;
    border: 1px solid var(--border);
    background: #0d0d0d;
  }
  .article-body pre.mono-block .mono-inner {
    display: block;
    padding: 24px;
    background: none;
    border: none;
    color: #c9d1d9;
    font-size: 0.85rem;
    line-height: 1.7;
    white-space: pre;
    overflow-x: auto;
    font-family: 'SF Mono', 'Fira Code', monospace;
  }
  .article-author {
    margin-top: 64px;
    padding: 32px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
  }
  .author-info {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .author-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--accent-dim);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
  }
  .author-name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    color: var(--text);
  }
  .author-role {
    font-size: 0.88rem;
    color: var(--text-tertiary);
    margin-top: 2px;
  }
  @media (max-width: 767px) {
    .article {
      padding: 100px 0 60px;
    }
    .article-body pre.mono-block .mono-inner {
      font-size: 0.78rem;
      padding: 16px;
    }
    .article-author {
      padding: 24px;
    }
    .author-info {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
