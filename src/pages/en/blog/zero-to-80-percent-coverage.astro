    align-items: center;
    gap: 8px;
    font-family: var(--font-heading);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-tertiary);
    transition: color var(--transition);
    margin-bottom: 48px;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .back-link-bottom {
    margin-bottom: 0;
    margin-top: 48px;
  }

  .article-header {
