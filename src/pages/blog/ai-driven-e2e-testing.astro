    margin-bottom: 0.8em;
    letter-spacing: -0.01em;
  }

  .article-body h3 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text);
    margin-top: 2em;
    margin-bottom: 0.6em;
  }

